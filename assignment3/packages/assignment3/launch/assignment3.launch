<launch>
  <node pkg="assignment3"
        type="navigator_node.py"
        name="assignment3_navigator"
        output="screen">

    <param name="robot_name"             value="bear"/>
    <param name="cmd_topic"              value="/bear/car_cmd_switch_node/cmd"/>

    <!-- Hareket hızları -->
    <param name="linear_speed"           value="0.18"/>
    <param name="align_linear_speed"     value="0.10"/>
    <param name="handoff_linear_speed"   value="0.06"/>
    <param name="handoff_duration_sec"   value="1.2"/>   <!-- 1.0→1.2: node geçişinde daha yumuşak -->

    <!-- Açısal kontrol -->
    <param name="angular_gain"           value="0.7"/>
    <param name="max_angular_speed"      value="0.60"/>
    <param name="yaw_bias"               value="0.05"/>  <!-- kod default'u; kameraya göre ayarla -->

    <!--
      align_angle_max:
        Eski launch'ta 0.35 rad vardı — bu çok geniş, robot neredeyse hiç
        hizalanmadan düz gidiyordu.  Kod default'u 0.20 rad (~11°) olarak
        güncellendi; daha sıkı hizalama sağlar.
    -->
    <param name="align_angle_max"        value="0.20"/>

    <!-- Hedef tag arama (tag kaybolunca) -->
    <param name="search_angular_speed"   value="0.3"/>  <!-- N2->N6 gibi sola aramalarda daha güçlü dönüş -->
    <param name="search_linear_speed"    value="0.02"/>

    <!--
      proximity_threshold:
        Eski launch'ta 0.18 m vardı — bu çok küçük, robot tag'a çarpacak
        kadar yaklaşmadan "reached" basmıyordu.
        Kod default'u 0.45 m; fiziksel lab ortamında 0.30 m iyi bir başlangıç.
    -->
    <param name="proximity_threshold"    value="0.30"/>

    <!-- Tag algılama -->
    <param name="detection_stale_sec"    value="1.2"/>
    <param name="aruco_dictionary"       value="DICT_5X5_50"/>

  </node>
</launch>
